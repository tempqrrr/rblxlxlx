local function kbDisplay(kb)
    if typeof(kb) == "EnumItem" then return kb.Name end
    return "false"
end

local function parseKB(txt)
    if not txt or txt == "" then return false end
    local lower = txt:lower()
    if lower == "false" or lower == "none" or lower == "nil" then return false end

    local candidates = { txt, txt:upper(), txt:sub(1,1):upper() .. txt:sub(2):lower() }
    for _, c in ipairs(candidates) do
        local ok, k = pcall(function() return Enum.KeyCode[c] end)
        if ok and typeof(k) == "EnumItem" then return k end
    end
    return nil
end


