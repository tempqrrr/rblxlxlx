function setupko()
    if not target then warn('no target') return end
    local bodyEffects = target:FindFirstChild("BodyEffects")
    if not bodyEffects then warn('couldnt find BodyEffects') return end
    local ko = bodyEffects:FindFirstChild("K.O")
    if not ko then warn('couldnt find ko') return end

    koconn = ko.Changed:Connect(function(nv)
        if nv == true then
            print("target died")
            if tbconn then tbconn:Disconnect() tbconn = nil end
            if koconn then koconn:Disconnect() koconn = nil end
            target = nil
        end
    end) -- ko is a boolvalue that has the value property, so we wait for the value to change to true
end




function connectTool(char)
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then warn('no tool') return end
	if not WhitelistedTools[tool.Name] then return end
    local ammo = tool:FindFirstChild("Ammo")
    local maxAmmo = tool:FindFirstChild("MaxAmmo")

    if not ammo then
        warn('no ammo path')
        return
    end
    if not maxAmmo then
        warn('no maxammo path')
        return
    end
    local ma = maxAmmo.Value

    local toolconn = ammo.Changed:Connect(function(nV)
        if not listen then return end
        if nV == ma then return end

        local hitPart1 = mouse.Target

        task.wait(HostDelay)

        if held and hitPart1.Name == "Hitbox" then
            t:Activate()
            target = hitPart1:FindFirstAncestorOfClass("Model")
            setupko()
        end

        if tbconn then
            return
        end

        local oldTick = tick()
        tbconn = runService.RenderStepped:Connect(function()
            if not held then return end
            if tick() - oldTick >= TBDelay then
                local hitPart = mouse.Target
                if hitPart.Name == "Hitbox" then
                    if target then
                        if hitPart:FindFirstAncestorOfClass("Model") == target then -- same target
                            t:Activate()
                            oldTick = tick()
                        end
                    else
                        t:Activate()
                        oldTick = tick()
                        target = hitPart:FindFirstAncestorOfClass("Model")
                        setupko()
                    end
                end
            end
        end)
    end)
    return toolconn
end


function sethost(plr)
    local conns = {}
    local entry = {player = plr, conns = conns}
    table.insert(playersconnected, entry)

    local function setToolConn(c)
        if conns.tool then conns.tool:Disconnect() end
        conns.tool = c
    end

    local function bindChar(char)
        if conns.added then conns.added:Disconnect() conns.added = nil end
        if conns.removed then conns.removed:Disconnect() conns.removed = nil end
        setToolConn(nil)

        if char:FindFirstChildOfClass("Tool") then
            setToolConn(connectTool(char))
        end

        conns.added = char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then setToolConn(connectTool(char)) end
        end)
        conns.removed = char.ChildRemoved:Connect(function(child)
            if child:IsA("Tool") then setToolConn(nil) end
        end)
    end

    bindChar(plr.Character or plr.CharacterAdded:Wait())
    conns.death = plr.CharacterAdded:Connect(bindChar)
end


function removehost(plr)
    for i, entry in ipairs(playersconnected) do
        if entry.player == plr then
            for k, x in pairs(entry.conns) do
                if x then x:Disconnect() end
                entry.conns[k] = nil
            end
            table.remove(playersconnected, i)
            break
        end
    end
end


